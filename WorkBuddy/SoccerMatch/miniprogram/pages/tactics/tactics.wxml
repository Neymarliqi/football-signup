<!-- pages/tactics/tactics.wxml -->
<view class="container">
  <!-- 足球场 -->
  <view class="field-container">
    <view class="field" id="field" bindtap="onFieldTap">
      <!-- 场地线条 -->
      <view class="field-lines">
        <!-- 外边框 -->
        <view class="field-border"></view>
        <!-- 中线 -->
        <view class="center-line"></view>
        <!-- 中圈 -->
        <view class="center-circle"></view>
        <!-- 球门区（上） -->
        <view class="goal-area-top"></view>
        <!-- 禁区（上） -->
        <view class="penalty-area-top"></view>
        <!-- 球门区（下） -->
        <view class="goal-area-bottom"></view>
        <!-- 禁区（下） -->
        <view class="penalty-area-bottom"></view>

      </view>

      <!-- 场上球员 -->
      <view 
        wx:for="{{onFieldPlayers}}" 
        wx:key="openid"
        class="player {{selectedPlayer === item.openid ? 'selected' : ''}} {{draggingPlayer === item.openid ? 'dragging' : ''}}"
        style="left: {{item.x}}%; top: {{item.y}}%; {{draggingPlayer === item.openid ? 'z-index: 100;' : ''}}"
        bindtouchstart="onPlayerDragStart"
        bindtouchmove="onPlayerDragMove"
        bindtouchend="onPlayerDragEnd"
        data-openid="{{item.openid}}"
        data-index="{{index}}"
        data-type="onField"
      >
        <view class="player-avatar-wrap">
          <image class="player-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view wx:if="{{item.positionLabel}}" class="position-tag">{{item.positionLabel}}</view>
        </view>
        <text class="player-name">{{item.shortName}}</text>
      </view>

      <!-- 拖拽中的球员（跟随手指） -->
      <view 
        wx:if="{{draggingPlayer && dragInfo}}"
        class="player dragging"
        style="left: {{dragInfo.x}}px; top: {{dragInfo.y}}px; position: fixed; z-index: 999; pointer-events: none;"
      >
        <view class="player-avatar-wrap">
          <image class="player-avatar" src="{{dragInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view wx:if="{{dragInfo.positionLabel}}" class="position-tag">{{dragInfo.positionLabel}}</view>
        </view>
        <text class="player-name">{{dragInfo.shortName}}</text>
      </view>
    </view>
  </view>

  <!-- 分隔线 -->
  <view class="divider">
    <text class="divider-text">选择上场球员</text>
  </view>

  <!-- 替补球员 -->
  <view class="bench-container">
    <view 
      wx:for="{{benchPlayers}}" 
      wx:key="openid"
      class="bench-player {{draggingPlayer === item.openid ? 'dragging' : ''}}"
      bindtouchstart="onPlayerDragStart"
      bindtouchmove="onPlayerDragMove"
      bindtouchend="onPlayerDragEnd"
      data-openid="{{item.openid}}"
      data-index="{{index}}"
      data-type="bench"
    >
      <view class="player-avatar-wrap">
        <image class="bench-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view wx:if="{{item.positionLabel}}" class="position-tag">{{item.positionLabel}}</view>
      </view>
      <text class="bench-name">{{item.shortName}}</text>
    </view>
  </view>

  <!-- 底部保存按钮 -->
  <view class="bottom-bar">
    <button class="save-btn" bindtap="saveTactics">保存</button>
  </view>
</view>
