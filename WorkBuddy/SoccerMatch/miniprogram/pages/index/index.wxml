<!-- pages/index/index.wxml - 首页活动列表 -->
<view class="container">
  
  <!-- 顶部横幅 -->
  <view class="header-banner">
    <view class="header-inner">
      <view class="header-title">
        <text class="ball-icon">⚽</text>
        <text class="title-text">约球助手</text>
      </view>
      <view class="header-sub">随时随地，召集队友</view>
    </view>
    <!-- 管理员入口 -->
    <view class="admin-btn" wx:if="{{isAdmin}}" bindtap="goAdmin">
      <text>⚙ 管理</text>
    </view>
  </view>

  <!-- 公告栏 -->
  <view class="announce-wrap" wx:if="{{announcements.length > 0}}">
    <view class="announce-header">
      <text class="announce-icon">📢</text>
      <text class="announce-title">公告</text>
    </view>
    <swiper class="announce-swiper" autoplay circular interval="4000" vertical="{{true}}" style="height: 60rpx;">
      <swiper-item wx:for="{{announcements}}" wx:key="_id">
        <view class="announce-item">
          <text class="announce-text">{{item.content}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item {{activeFilter === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">全部</view>
    <view class="filter-item {{activeFilter === 'upcoming' ? 'active' : ''}}" bindtap="setFilter" data-type="upcoming">未开始</view>
    <view class="filter-item {{activeFilter === 'ongoing' ? 'active' : ''}}" bindtap="setFilter" data-type="ongoing">进行中</view>
    <view class="filter-item {{activeFilter === 'finished' ? 'active' : ''}}" bindtap="setFilter" data-type="finished">已结束</view>
  </view>

  <!-- 活动列表 -->
  <view wx:if="{{activities.length === 0}}" class="empty-state" bindtap="goCreate">
    <text style="font-size: 100rpx;">⚽</text>
    <text>暂无活动</text>
    <text class="empty-sub">点击右下角「发布活动」开始约球！</text>
  </view>

  <view wx:for="{{activities}}" wx:key="_id" class="activity-card" bindtap="goDetail" data-id="{{item._id}}">
    
    <!-- 活动状态标签 -->
    <view class="card-top flex-between">
      <view class="act-status-tag tag {{item.statusClass}}">{{item.statusText}}</view>
      <view class="act-time-badge">
        <text class="icon-text">📅 </text>
        <text>{{item.displayDate}}</text>
      </view>
    </view>

    <!-- 活动标题 -->
    <view class="act-title">{{item.title}}</view>

    <!-- 活动信息 -->
    <view class="act-info-row">
      <view class="act-info-item">
        <text class="info-icon">⏰</text>
        <text class="info-text">{{item.time}}</text>
      </view>
      <view class="act-info-item">
        <text class="info-icon">📍</text>
        <text class="info-text" style="max-width: 280rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{item.location}}</text>
      </view>
    </view>

    <view class="act-info-row">
      <view class="act-info-item">
        <text class="info-icon">⚽</text>
        <text class="info-text">{{item.matchType}}</text>
      </view>
      <view class="act-info-item">
        <text class="info-icon">💰</text>
        <text class="info-text">{{item.fee > 0 ? item.fee + '元/人' : '免费'}}</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 报名人数进度 -->
    <view class="register-section">
      <view class="flex-between mb-10">
        <text class="register-label">已报名</text>
        <text class="register-count">
          <text class="count-num {{item.confirmedCount >= item.maxPlayers ? 'count-full' : 'count-ok'}}">{{item.confirmedCount}}</text>
          <text class="count-sep">/</text>
          <text class="count-max">{{item.maxPlayers}}人</text>
        </text>
      </view>
      <!-- 进度条 -->
      <view class="progress-bar-bg">
        <view class="progress-bar-fill {{item.confirmedCount >= item.maxPlayers ? 'bar-full' : 'bar-normal'}}" style="width: {{item.progressPercent}}%"></view>
      </view>
    </view>

    <!-- 球员头像列表 -->
    <view class="players-section">
      <view class="players-title">
        <text>✅ 已报名 ({{item.confirmedCount}})</text>
        <text wx:if="{{item.pendingCount > 0}}" class="pending-hint">  ⏳ 待定 {{item.pendingCount}}人</text>
        <text wx:if="{{item.leaveCount > 0}}" class="leave-hint">  🙅 请假 {{item.leaveCount}}人</text>
      </view>
      <view class="avatar-list">
        <view wx:for="{{item.confirmedPlayers}}" wx:for-item="player" wx:key="openid" class="avatar-item">
          <image class="avatar-sm" src="{{player.avatarUrl || placeholderAvatar}}" mode="aspectFill"></image>
          <text class="avatar-name">{{player.shortName}}</text>
        </view>
        <view wx:if="{{item.confirmedCount > 6}}" class="avatar-more">
          <view class="more-circle">+{{item.confirmedCount - 6}}</view>
        </view>
      </view>
    </view>

    <!-- 我的报名状态 -->
    <view class="my-status-row" wx:if="{{item.myStatus}}">
      <text class="my-status-label">我的状态：</text>
      <view class="tag {{item.myStatusClass}}">{{item.myStatusText}}</view>
    </view>

    <!-- 操作按钮区 -->
    <view class="card-btns">
      <!-- 主操作 -->
      <view class="card-btn btn-view" catchtap="goDetail" data-id="{{item._id}}">查看详情</view>
      
      <!-- 功能操作 -->
      <view class="card-btn btn-tactics" wx:if="{{item.myStatus === 'confirmed'}}" 
            catchtap="goTactics" data-id="{{item._id}}">战术板</view>
      
      <!-- 分隔线（有管理操作时显示） -->
      <view class="action-divider" wx:if="{{item.canEdit || item.canCancel || item.canDelete}}"></view>
      
      <!-- 管理操作（弱化） -->
      <view class="action-link" wx:if="{{item.canEdit}}" catchtap="goEdit" data-id="{{item._id}}">编辑</view>
      <view class="action-link" wx:if="{{item.canCancel}}" catchtap="cancelActivity" data-id="{{item._id}}">取消</view>
      <view class="action-link delete" wx:if="{{item.canDelete}}" catchtap="deleteActivity" data-id="{{item._id}}">删除</view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view style="height: 120rpx;"></view>
</view>

<!-- 悬浮发布按钮（所有人可见） -->
<view class="fab-btn" bindtap="goCreate">
  <text class="fab-icon">＋</text>
  <text class="fab-text">发布活动</text>
</view>
