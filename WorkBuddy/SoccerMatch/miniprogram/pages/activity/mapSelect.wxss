/* pages/activity/mapSelect.wxss */

/* 页面容器 - 从下往上滑入动画 */
.container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
  z-index: 1000;
}

.container.show {
  transform: translateY(0);
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.nav-cancel {
  font-size: 32rpx;
  color: #333;
  padding: 20rpx 0;
  min-width: 100rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #000;
}

.nav-confirm {
  font-size: 32rpx;
  color: #999;
  padding: 20rpx 0;
  min-width: 100rpx;
  text-align: right;
}

.nav-confirm.active {
  color: #07c160;
  font-weight: 500;
}

/* 搜索区域 */
.search-section {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 76rpx;
  background: #f5f5f5;
  border-radius: 38rpx;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  height: 76rpx;
  line-height: 76rpx;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  background: #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  margin-left: 16rpx;
}

.search-cancel {
  font-size: 32rpx;
  color: #333;
  margin-left: 24rpx;
  padding: 20rpx 0;
}

/* 地图区域 */
.map-section {
  position: relative;
  height: 400rpx;
  flex-shrink: 0;
}

.map {
  width: 100%;
  height: 100%;
}

/* 中心点标记 */
.center-marker {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -100%);
  pointer-events: none;
  z-index: 10;
}

.marker-pin {
  width: 36rpx;
  height: 36rpx;
  background: #07c160;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.marker-shadow {
  width: 20rpx;
  height: 8rpx;
  background: rgba(0,0,0,0.2);
  border-radius: 50%;
  margin: 8rpx auto 0;
}

/* 重新定位按钮 */
.locate-btn {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.locate-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #666;
  border-radius: 50%;
  position: relative;
}

.locate-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  background: #07c160;
  border-radius: 50%;
}

/* 地点列表区域 */
.poi-list-section {
  flex: 1;
  background: #fff;
  overflow: hidden;
}

.poi-scroll {
  height: 100%;
}

/* 地点项 */
.poi-item {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  background: #fff;
}

.poi-item:active {
  background: #f9f9f9;
}

.poi-item.current-location {
  background: #f0fff5;
}

.poi-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.poi-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.poi-name {
  font-size: 34rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.poi-address {
  font-size: 28rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.poi-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 24rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.poi-check.checked {
  background: #07c160;
  border-color: #07c160;
}

.check-icon {
  width: 24rpx;
  height: 16rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg) translate(2rpx, -4rpx);
}

.poi-distance {
  font-size: 26rpx;
  color: #999;
  margin-left: 24rpx;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}