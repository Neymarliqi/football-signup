/* pages/activity/create.wxss */

.page-header {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 20rpx;
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
}

.page-header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

/* 表单项 */
.form-item { margin-bottom: 30rpx; }
.form-item:last-child { margin-bottom: 0; }

.form-label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.required { color: #e74c3c; }

.form-input {
  width: 100%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid #e8e8e8;
  box-sizing: border-box;
  min-height: 88rpx;
  line-height: 1.4;
}

.form-textarea {
  width: 100%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e8e8e8;
  min-height: 160rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.form-picker {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  box-sizing: border-box;
}

.form-picker.placeholder { color: #bbb; }
.picker-arrow { font-size: 36rpx; color: #bbb; }

.form-hint {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 单选组 */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.radio-active {
  color: #2ecc71;
  border-color: #2ecc71;
  background: #e8f8f0;
  font-weight: bold;
}

/* 导航地址 */
.nav-address-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-address-display {
  flex: 1;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  box-sizing: border-box;
}

.nav-address-display.placeholder {
  color: #bbb;
}

.nav-address-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.clear-location {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
  white-space: nowrap;
}

.clear-location:active {
  color: #666;
}

/* 数字输入 */
.number-input-row {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 10rpx;
}

.num-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #555;
  font-weight: bold;
}

.num-btn-disabled {
  background: #e8e8e8;
  color: #bbb;
}

.num-display {
  font-size: 38rpx;
  font-weight: bold;
  color: #1a1a2e;
  min-width: 120rpx;
  text-align: center;
}

.num-display.disabled-text {
  color: #999;
  font-weight: normal;
}

.number-input-row.disabled {
  opacity: 0.7;
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-label { font-size: 28rpx; color: #333; }

/* 赛制类型区域 */
.match-type-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 自定义类型区域 */
.custom-types-section {
  margin-top: 8rpx;
}

.custom-types-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

/* 自定义类型项 */
.custom-type-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 20rpx 14rpx 28rpx;
}

.custom-type-item text {
  flex: 1;
}

.custom-type-actions {
  display: flex;
  gap: 16rpx;
  margin-left: 12rpx;
}

.action-icon {
  font-size: 24rpx;
  padding: 8rpx;
  opacity: 0.7;
}

.action-icon:active {
  opacity: 1;
}

/* 添加自定义按钮 */
.add-custom-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ccc;
  color: #666;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.add-custom-btn:active {
  background: #f5f5f5;
}

.add-icon {
  font-size: 32rpx;
  font-weight: bold;
}

/* 自定义输入区域 */
.custom-input-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}

.custom-input {
  margin-top: 0;
}

.custom-input-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.btn-confirm {
  padding: 16rpx 32rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.btn-confirm:active {
  opacity: 0.9;
}

.btn-cancel-text {
  padding: 16rpx 24rpx;
  color: #999;
  font-size: 26rpx;
}

.btn-cancel-text:active {
  color: #666;
}

/* 最大人数选择 */
.max-players-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 截止时间选项 */
.deadline-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.deadline-option {
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.deadline-active {
  color: #2ecc71;
  border-color: #2ecc71;
  background: #e8f8f0;
  font-weight: bold;
}

/* 不限/限制切换 */
.unlimited-toggle {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.toggle-item {
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.toggle-active {
  color: #2ecc71;
  border-color: #2ecc71;
  background: #e8f8f0;
  font-weight: bold;
}

/* 底部固定提交栏 */
.fixed-submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  z-index: 100;
}

.fixed-submit-bar .submit-btn {
  width: 100%;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary {
  background: #07c160;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.35);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.995);
}

.fixed-submit-bar .action-link {
  font-size: 28rpx;
  color: #999;
  padding: 12rpx 24rpx;
}

.fixed-submit-bar .action-link.delete {
  color: #e74c3c;
}

.fixed-submit-bar .action-link:active {
  opacity: 0.7;
}

/* 编辑模式下的按钮行 */
.edit-actions-row {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 0;
}

.edit-actions-row .flex-1 {
  flex: 1;
}

/* 分隔线 */
.action-divider {
  width: 2rpx;
  height: 40rpx;
  background: #e8e8e8;
  margin: 0 20rpx;
}

/* 次要操作按钮（灰色文字） */
.action-link-secondary {
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  color: #999;
  white-space: nowrap;
}

.action-link-secondary:active {
  color: #666;
}

.btn-cancel {
  padding: 28rpx 40rpx;
  font-size: 28rpx;
  color: #999;
  background: transparent;
}

.btn-cancel:active {
  opacity: 0.6;
}
