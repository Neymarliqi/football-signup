<!-- pages/activity/create.wxml - 发布/编辑活动 -->
<view class="container">
  <view class="page-header">
    <text class="page-header-title">{{isEdit ? '✏ 编辑活动' : '🆕 发布活动'}}</text>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="section-title">📋 基本信息</view>
    
    <view class="form-item">
      <view class="form-label">活动标题 <text class="required">*</text></view>
      <input class="form-input" value="{{form.title}}" bindinput="onInput" data-key="title"
             placeholder="例：周末11人制足球赛" maxlength="30"/>
    </view>

    <view class="form-item">
      <view class="form-label">活动描述</view>
      <textarea class="form-textarea" value="{{form.description}}" bindinput="onInput" data-key="description"
                placeholder="简短描述本次活动...（可选）" maxlength="200"/>
    </view>

    <view class="form-item">
      <view class="form-label">赛制类型 <text class="required">*</text></view>
      <view class="radio-group">
        <view wx:for="{{matchTypes}}" wx:key="value"
              class="radio-item {{form.matchType === item.value ? 'radio-active' : ''}}"
              bindtap="selectMatchType" data-value="{{item.value}}">
          {{item.label}}
        </view>
      </view>
    </view>
  </view>

  <!-- 时间设置 -->
  <view class="card">
    <view class="section-title">⏰ 时间设置</view>

    <view class="form-item">
      <view class="form-label">踢球日期 <text class="required">*</text></view>
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="form-picker {{form.date ? '' : 'placeholder'}}">
          <text>{{form.date || '选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">开始时间 <text class="required">*</text></view>
      <picker mode="time" value="{{form.startTime}}" bindchange="onStartTimeChange">
        <view class="form-picker {{form.startTime ? '' : 'placeholder'}}">
          <text>{{form.startTime || '选择开始时间'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">结束时间</view>
      <picker mode="time" value="{{form.endTime}}" bindchange="onEndTimeChange">
        <view class="form-picker {{form.endTime ? '' : 'placeholder'}}">
          <text>{{form.endTime || '选择结束时间（可选）'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 地点设置 -->
  <view class="card">
    <view class="section-title">📍 地点设置</view>

    <view class="form-item">
      <view class="form-label">场地名称 <text class="required">*</text></view>
      <input class="form-input" value="{{form.locationName}}" bindinput="onInput" data-key="locationName"
             placeholder="例：XXX足球场 A号场"/>
    </view>

    <view class="form-item">
      <view class="form-label">详细地址 <text class="required">*</text></view>
      <view class="location-row">
        <input class="form-input flex-1" value="{{form.location}}" bindinput="onInput" data-key="location"
               placeholder="例：XX市XX区XX路XX号"/>
        <view class="pick-location-btn" bindtap="pickLocation">📍选点</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">场地类型</view>
      <view class="radio-group">
        <view wx:for="{{fieldTypes}}" wx:key="value"
              class="radio-item {{form.fieldType === item.value ? 'radio-active' : ''}}"
              bindtap="selectFieldType" data-value="{{item.value}}">
          {{item.label}}
        </view>
      </view>
    </view>
  </view>

  <!-- 报名设置 -->
  <view class="card">
    <view class="section-title">👥 报名设置</view>

    <view class="form-item">
      <view class="form-label">最大人数 <text class="required">*</text></view>
      <view class="number-input-row">
        <view class="num-btn" bindtap="decreaseMax">－</view>
        <text class="num-display">{{form.maxPlayers}}人</text>
        <view class="num-btn" bindtap="increaseMax">＋</view>
      </view>
      <view class="form-hint">当前设置：{{form.maxPlayers}}人（超出后可待定候补）</view>
    </view>

    <view class="form-item">
      <view class="form-label">费用（元/人）</view>
      <view class="number-input-row">
        <view class="num-btn" bindtap="decreaseFee">－</view>
        <text class="num-display">{{form.fee === 0 ? '免费' : form.fee + '元'}}</text>
        <view class="num-btn" bindtap="increaseFee">＋</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">报名截止时间</view>
      <picker mode="dateTime" value="{{form.deadline}}" bindchange="onDeadlineChange">
        <view class="form-picker {{form.deadline ? '' : 'placeholder'}}">
          <text>{{form.deadline || '截止报名时间（可选）'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">允许待定</view>
      <view class="switch-row">
        <text class="switch-label">开启待定候补功能</text>
        <switch checked="{{form.allowPending}}" bindchange="onAllowPendingChange" color="#2ecc71"/>
      </view>
    </view>
  </view>

  <!-- 注意事项/公告 -->
  <view class="card">
    <view class="section-title">📢 注意事项</view>
    <textarea class="form-textarea" value="{{form.notice}}" bindinput="onInput" data-key="notice"
              placeholder="天气注意事项、装备要求、集合点说明等..." maxlength="500"/>
    <view class="char-count">{{form.notice.length}}/500</view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <view class="submit-btn" bindtap="submit">
      {{isEdit ? '💾 保存修改' : '🚀 发布活动'}}
    </view>
    <view class="cancel-btn" wx:if="{{isEdit}}" bindtap="cancelActivity">❌ 取消活动</view>
  </view>

  <view style="height: 60rpx;"></view>
</view>
