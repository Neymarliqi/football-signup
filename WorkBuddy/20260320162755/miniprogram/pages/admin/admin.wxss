/* pages/admin/admin.wxss */

.admin-header {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
}

.admin-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 10rpx;
}

.admin-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.quick-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.qb-icon { font-size: 44rpx; }

.qb-label {
  font-size: 22rpx;
  color: #555;
  text-align: center;
}

/* section title */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.create-btn {
  font-size: 24rpx;
  color: #2ecc71;
  background: #e8f8f0;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  padding: 24rpx 0;
  font-size: 26rpx;
}

/* 活动管理列表 */
.admin-act-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
  flex-wrap: wrap;
}

.admin-act-item:last-child { border-bottom: none; }

.admin-act-info { flex: 1; min-width: 0; }

.admin-act-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-act-meta {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.admin-act-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.admin-act-btns {
  display: flex;
  gap: 12rpx;
}

.admin-btn {
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.edit-btn { background: #eaf4fd; color: #3498db; }
.view-btn { background: #e8f8f0; color: #2ecc71; }

/* 公告管理 */
.announce-manage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.announce-manage-item:last-child { border-bottom: none; }

.announce-content {
  flex: 1;
  font-size: 26rpx;
  color: #555;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.announce-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.ann-btn {
  padding: 8rpx 16rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
}

.ann-active { background: #e8f8f0; color: #2ecc71; }
.ann-inactive { background: #f5f5f5; color: #aaa; }
.ann-delete { background: #fdecea; color: #e74c3c; }

/* 球员列表 */
.member-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.member-item:last-child { border-bottom: none; }

.member-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: #e0e0e0;
  flex-shrink: 0;
}

.member-info { flex: 1; }

.member-name { font-size: 26rpx; color: #333; font-weight: 500; }

.member-pos { font-size: 22rpx; color: #aaa; margin-top: 4rpx; }

.member-stat { }
.member-games { font-size: 22rpx; color: #2ecc71; font-weight: bold; }

.member-admin-badge {
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  width: 86%;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.modal-textarea {
  width: 100%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 140rpx;
  box-sizing: border-box;
  border: 2rpx solid #e8e8e8;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-cancel {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 44rpx;
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
}

.modal-confirm {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 通用 tag */
.tag-green { background: #e8f8f0; color: #2ecc71; }
.tag-gray { background: #f0f0f0; color: #999; }
.tag-red { background: #fdecea; color: #e74c3c; }
.tag-blue { background: #eaf4fd; color: #3498db; }
