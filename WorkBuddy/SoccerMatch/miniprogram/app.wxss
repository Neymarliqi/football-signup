/* app.wxss - 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* ========== 通用容器 ========== */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* ========== 卡片样式 ========== */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

/* ========== 按钮 ========== */
.btn-primary {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  border-radius: 50rpx;
  padding: 22rpx 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  text-align: center;
}

.btn-secondary {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  border-radius: 50rpx;
  padding: 22rpx 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  text-align: center;
}

.btn-warning {
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
  border-radius: 50rpx;
  padding: 22rpx 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  text-align: center;
}

.btn-danger {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  border-radius: 50rpx;
  padding: 22rpx 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  text-align: center;
}

.btn-ghost {
  background: transparent;
  color: #666;
  border-radius: 50rpx;
  padding: 22rpx 50rpx;
  font-size: 30rpx;
  border: 2rpx solid #ddd;
  text-align: center;
}

/* ========== 状态标签 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.tag-green {
  background: #e8f8f0;
  color: #2ecc71;
}

.tag-yellow {
  background: #fef9e7;
  color: #f39c12;
}

.tag-red {
  background: #fdecea;
  color: #e74c3c;
}

.tag-gray {
  background: #f0f0f0;
  color: #999;
}

.tag-blue {
  background: #eaf4fd;
  color: #3498db;
}

/* ========== 头像 ========== */
.avatar {
  border-radius: 50%;
  background: #e0e0e0;
}

.avatar-sm {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.avatar-md {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

/* ========== 分割线 ========== */
.divider {
  height: 2rpx;
  background: #f0f0f0;
  margin: 24rpx 0;
}

/* ========== flex 工具 ========== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

/* ========== 文字 ========== */
.text-primary { color: #2ecc71; }
.text-blue { color: #3498db; }
.text-gray { color: #999; }
.text-dark { color: #1a1a2e; }
.text-bold { font-weight: bold; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 34rpx; }
.text-xl { font-size: 40rpx; }

/* ========== 间距 ========== */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }
.mr-10 { margin-right: 10rpx; }

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #bbb;
}

.empty-state text {
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* ========== picker-view 选中指示器（自定义 date-picker 使用）========== */
picker-view {
  height: 400rpx;
}

