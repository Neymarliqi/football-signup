/* pages/team/settings.wxss */

/* 封面图 */
.cover-upload-wrap {
  margin-top: 16rpx;
}

.cover-preview {
  position: relative;
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.placeholder-icon { font-size: 60rpx; opacity: 0.4; }
.placeholder-text { font-size: 26rpx; color: #999; }

.cover-change-badge {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(4rpx);
}

/* Logo */
.logo-upload-wrap {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.logo-preview {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f5f5f5;
  border: 4rpx dashed #ddd;
}

.logo-img {
  width: 100%;
  height: 100%;
}

.logo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-placeholder .placeholder-icon {
  font-size: 56rpx;
  opacity: 0.3;
}

.logo-change-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
}

/* 表单 */
.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child { margin-bottom: 0; }

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.form-input {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  min-height: 140rpx;
}

.char-count {
  font-size: 22rpx;
  color: #bbb;
  text-align: right;
  margin-top: 8rpx;
}

.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  padding: 16rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.radio-active {
  background: #e8f8f0;
  color: #27ae60;
  border-color: #2ecc71;
  font-weight: bold;
}

.save-btn {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 24rpx;
}

.invite-desc {
  font-size: 26rpx;
  color: #999;
  margin: 12rpx 0 20rpx;
}

.btn-share-invite {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 危险区 */
.danger-zone {
  border: 2rpx solid #fde8e8;
  background: #fff5f5;
}

.danger-title {
  color: #e74c3c !important;
}

.danger-desc {
  font-size: 24rpx;
  color: #999;
  margin: 12rpx 0 20rpx;
}

.btn-danger {
  background: #fff;
  color: #e74c3c;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: 2rpx solid #e74c3c;
}
