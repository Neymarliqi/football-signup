<!-- pages/activity/create.wxml - 发布/编辑活动 -->
<view class="container">
  <view class="page-header">
    <text class="page-header-title">{{isEdit ? '✏ 编辑活动' : '🆕 发布活动'}}</text>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="section-title">📋 基本信息</view>

    <!-- 球队选择 -->
    <view class="form-item">
      <view class="form-label">所属球队</view>
      <view class="team-picker-btn" bindtap="pickTeam">
        <text wx:if="{{!form.teamId}}" class="picker-placeholder">不选择 = 公开活动（所有用户可见）</text>
        <text wx:if="{{form.teamId}}" class="team-picker-value">
          <text class="team-picker-icon">⚽</text> {{form.teamName}}
        </text>
        <text class="picker-arrow">›</text>
      </view>
      <view class="form-hint" wx:if="{{form.teamId}}">球队活动不会展示在首页，仅通过分享传播</view>
    </view>

    <view class="form-item">
      <view class="form-label">活动标题 <text class="required">*</text></view>
      <input class="form-input" value="{{form.title}}" bindinput="onInput" data-key="title"
             placeholder="例：周末11人制足球赛" maxlength="30"/>
    </view>

    <view class="form-item">
      <view class="form-label">活动描述</view>
      <textarea class="form-textarea" value="{{form.description}}" bindinput="onDescriptionInput"
                placeholder="简短描述本次活动...（可选）" maxlength="200"/>
    </view>

    <view class="form-item">
      <view class="form-label">赛制类型</view>
      <view class="match-type-wrap">
        <!-- 预设赛制类型 -->
        <view class="radio-group">
          <view wx:for="{{presetMatchTypes}}" wx:key="*this"
                class="radio-item {{form.matchType === item ? 'radio-active' : ''}}"
                bindtap="selectMatchType" data-value="{{item}}">
            {{item}}
          </view>
        </view>
        
        <!-- 自定义赛制类型 -->
        <view wx:if="{{customMatchTypes.length > 0}}" class="custom-types-section">
          <view class="custom-types-label">我的自定义</view>
          <view class="radio-group">
            <view wx:for="{{customMatchTypes}}" wx:key="*this" wx:for-index="idx"
                  class="radio-item custom-type-item {{form.matchType === item ? 'radio-active' : ''}}">
              <text bindtap="selectMatchType" data-value="{{item}}">{{item}}</text>
              <view class="custom-type-actions">
                <text class="action-icon" bindtap="editCustomMatchType" data-index="{{idx}}">✏️</text>
                <text class="action-icon" bindtap="deleteCustomMatchType" data-index="{{idx}}">🗑️</text>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 添加自定义按钮 -->
        <view wx:if="{{!showCustomInput}}" class="add-custom-btn" bindtap="showAddCustomMatchType">
          <text class="add-icon">+</text>
          <text>添加自定义赛制</text>
        </view>
        
        <!-- 自定义输入框 -->
        <view wx:if="{{showCustomInput}}" class="custom-input-wrap">
          <input class="form-input custom-input" 
                 value="{{form.customMatchTypeText}}"
                 bindinput="onCustomMatchTypeInput"
                 placeholder="请输入自定义赛制名称"
                 maxlength="10"
                 focus/>
          <view class="custom-input-actions">
            <view class="btn-confirm" bindtap="saveCustomMatchType">{{editingCustomIndex >= 0 ? '保存' : '添加'}}</view>
            <view class="btn-cancel-text" bindtap="cancelCustomInput">取消</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 可见范围（球队活动专属） -->
    <view class="form-item" wx:if="{{form.teamId}}">
      <view class="form-label">👁 可见范围</view>
      <view class="radio-group">
        <view class="radio-item {{form.visibility !== 'memberOnly' ? 'radio-active' : ''}}" bindtap="setVisibility" data-value="open">
          🌍 允许非成员参加（默认）
        </view>
        <view class="radio-item {{form.visibility === 'memberOnly' ? 'radio-active' : ''}}" bindtap="setVisibility" data-value="memberOnly">
          🔒 仅球队成员
        </view>
      </view>
      <view class="form-hint" wx:if="{{form.visibility !== 'memberOnly'}}">活动通过分享链接传播，任何人都可报名</view>
      <view class="form-hint" wx:else>仅球队成员可以报名参加</view>
    </view>
  </view>


  <!-- 时间设置 -->
  <view class="card">
    <view class="section-title">⏰ 时间设置</view>

    <view class="form-item">
      <view class="form-label">踢球日期 <text class="required">*</text></view>
      <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
        <view class="form-picker {{form.date ? '' : 'placeholder'}}">
          <text>{{form.date || '选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">开始时间 <text class="required">*</text></view>
      <picker mode="time" value="{{form.startTime}}" bindchange="onStartTimeChange">
        <view class="form-picker {{form.startTime ? '' : 'placeholder'}}">
          <text>{{form.startTime || '选择开始时间'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">结束时间</view>
      <picker mode="time" value="{{form.endTime}}" bindchange="onEndTimeChange">
        <view class="form-picker {{form.endTime ? '' : 'placeholder'}}">
          <text>{{form.endTime || '选择结束时间（可选）'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 地点设置 -->
  <view class="card">
    <view class="section-title">📍 地点设置</view>

    <view class="form-item">
      <view class="form-label">场地名称 <text class="required">*</text></view>
      <input class="form-input" value="{{form.locationName}}" bindinput="onInput" data-key="locationName"
             placeholder="例：XXX足球场 A号场"/>
    </view>

    <view class="form-item">
      <view class="form-label">导航地址</view>
      <view class="nav-address-wrap">
        <view class="nav-address-display {{form.locationName ? '' : 'placeholder'}}" bindtap="pickLocation">
          <text class="nav-address-text">{{form.locationName || '点击选择导航地址（可选）'}}</text>
          <text class="picker-arrow">›</text>
        </view>
        <text wx:if="{{form.locationName}}" class="clear-location" bindtap="clearLocation">清除</text>
      </view>
      <view class="form-hint" wx:if="{{form.locationName}}">已选择导航地址，用户可直接导航前往</view>
    </view>

    <view class="form-item">
      <view class="form-label">场地类型</view>
      <view class="radio-group">
        <view wx:for="{{fieldTypes}}" wx:key="value"
              class="radio-item {{form.fieldType === item.value ? 'radio-active' : ''}}"
              bindtap="selectFieldType" data-value="{{item.value}}">
          {{item.label}}
        </view>
      </view>
    </view>
  </view>

  <!-- 报名设置 -->
  <view class="card">
    <view class="section-title">👥 报名设置</view>

    <view class="form-item">
      <view class="form-label">最大人数 <text class="required">*</text></view>
      <view class="max-players-wrap">
        <!-- 不限/限制切换 -->
        <view class="unlimited-toggle">
          <view class="toggle-item {{form.maxPlayers === 999 ? 'toggle-active' : ''}}" bindtap="setUnlimitedPlayers">不限人数</view>
          <view class="toggle-item {{form.maxPlayers !== 999 ? 'toggle-active' : ''}}" bindtap="setLimitedPlayers">限制人数</view>
        </view>
        <!-- 人数选择器（仅限制人数时显示） -->
        <view class="number-input-row" wx:if="{{form.maxPlayers !== 999}}">
          <view class="num-btn {{form.maxPlayers <= 2 ? 'num-btn-disabled' : ''}}" bindtap="decreaseMax">－</view>
          <text class="num-display">{{form.maxPlayers}}人</text>
          <view class="num-btn {{form.maxPlayers >= 50 ? 'num-btn-disabled' : ''}}" bindtap="increaseMax">＋</view>
        </view>
      </view>
      <!-- <view class="form-hint" wx:if="{{form.maxPlayers !== 999}}">当前设置：{{form.maxPlayers}}人（超出后可待定候补）</view> -->
    </view>

    <view class="form-item">
      <view class="form-label">费用</view>
      <view class="number-input-row disabled">
        <view class="num-btn num-btn-disabled">－</view>
        <text class="num-display disabled-text">{{form.fee === 0 ? '线下收费' : form.fee + '元'}}</text>
        <view class="num-btn num-btn-disabled">＋</view>
      </view>
      <view class="form-hint">费用功能暂未开放，默认线下收费</view>
    </view>

    <view class="form-item">
      <view class="form-label">报名截止时间</view>
      <view class="deadline-options">
        <view wx:for="{{deadlineOptions}}" wx:key="value"
              class="deadline-option {{selectedDeadline === item.value ? 'deadline-active' : ''}}"
              bindtap="selectDeadline" data-value="{{item.value}}">
          {{item.label}}
        </view>
      </view>
      <view class="form-hint" wx:if="{{form.deadlineDisplay}}">
        截止时间：{{form.deadlineDisplay}}
      </view>
    </view>

    <!-- 允许待定（暂时隐藏） -->
    <!-- <view class="form-item">
      <view class="form-label">允许待定</view>
      <view class="switch-row">
        <text class="switch-label">开启待定候补功能</text>
        <switch checked="{{form.allowPending}}" bindchange="onAllowPendingChange" color="#2ecc71"/>
      </view>
    </view> -->
  </view>

  <!-- 注意事项/公告（暂时隐藏） -->
  <!-- <view class="card">
    <view class="section-title">📢 注意事项</view>
    <textarea class="form-textarea" value="{{form.notice}}" bindinput="onInput" data-key="notice"
              placeholder="天气注意事项、装备要求、集合点说明等..." maxlength="500"/>
    <view class="char-count">{{form.notice.length}}/500</view>
  </view> -->

  <!-- 底部占位，防止被固定栏遮挡 -->
  <view style="height: 180rpx;"></view>
</view>

<!-- 底部固定提交栏 -->
<view class="fixed-submit-bar">
  <!-- 编辑模式：保存修改 + 取消活动 -->
  <view wx:if="{{isEdit}}" class="edit-actions-row">
    <view class="submit-btn btn-primary flex-1" bindtap="submit">保存修改</view>
    <view class="action-divider"></view>
    <view class="action-link-secondary" bindtap="cancelActivityInEdit">取消活动</view>
  </view>
  
  <!-- 创建模式：发布活动 -->
  <view wx:if="{{!isEdit}}" class="submit-btn btn-primary" bindtap="submit">
  发布活动
  </view>
</view>

<!-- 注册弹窗 -->
<register-modal show="{{showRegisterModal}}" bind:registered="onRegistered" bind:close="onCloseRegister" />
