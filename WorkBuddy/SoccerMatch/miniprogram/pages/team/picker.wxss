/* pages/team/picker.wxss */

.page-header {
  padding: 30rpx;
  margin-bottom: 10rpx;
}

.page-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
}

.team-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.2s;
}

.team-item:last-child { border-bottom: none; }

.team-item-active {
  background: #e8f8f0;
  margin: 0 -24rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
}

.team-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 40rpx;
}

.public-icon {
  background: linear-gradient(135deg, #e8f8f0, #d4f5e4);
}

.team-logo {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.logo-placeholder-text {
  font-size: 40rpx;
  opacity: 0.4;
}

.team-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.team-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.team-meta {
  font-size: 24rpx;
  color: #999;
}

.check-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #2ecc71;
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #bbb;
  gap: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.btn-create {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
