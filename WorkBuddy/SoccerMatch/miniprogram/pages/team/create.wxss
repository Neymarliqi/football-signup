/* pages/team/create.wxss */

.page-header {
  padding: 30rpx 30rpx 0;
}

.page-header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
}

/* 封面图 */
.cover-upload-wrap {
  margin-top: 20rpx;
}

.cover-preview {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.placeholder-icon {
  font-size: 64rpx;
  opacity: 0.4;
}

.placeholder-text {
  font-size: 28rpx;
  color: #999;
}

.placeholder-sub {
  font-size: 22rpx;
  color: #bbb;
}

.cover-change-badge {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(4rpx);
}

/* Logo */
.logo-upload-wrap {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-top: 20rpx;
}

.logo-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
  flex-shrink: 0;
}

.logo-img {
  width: 100%;
  height: 100%;
}

.logo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border: 4rpx dashed #ddd;
  border-radius: 50%;
}

.logo-placeholder .placeholder-icon {
  font-size: 64rpx;
  opacity: 0.3;
}

.logo-change-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.logo-hint {
  font-size: 24rpx;
  color: #999;
}

/* 表单 */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.required {
  color: #e74c3c;
  margin-left: 4rpx;
}

.form-input {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

.char-count {
  font-size: 22rpx;
  color: #bbb;
  text-align: right;
  margin-top: 8rpx;
}

.radio-group {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.radio-item {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.radio-active {
  background: #e8f8f0;
  color: #27ae60;
  border-color: #2ecc71;
  font-weight: bold;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 底部固定栏 */
.fixed-submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.submit-btn {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(46,204,113,0.3);
}

.submit-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
