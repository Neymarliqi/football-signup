/* pages/profile/edit-profile.wxss */

/* 页面容器 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 40rpx 30rpx 200rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 区块样式 */
.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

/* 头像部分 */
.avatar-wrapper {
  display: flex;
  justify-content: center;
}

.avatar-button {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  padding: 0;
  border-radius: 50%;
  overflow: hidden;
  background: #f0f0f0;
  border: none;
}

.avatar-button::after {
  border: none;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-button:active .avatar-mask {
  opacity: 1;
}

.camera-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.camera-text {
  font-size: 24rpx;
  color: #fff;
}

/* 昵称部分 */
.nickname-wrapper {
  margin-bottom: 24rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333;
}

.nickname-input::placeholder {
  color: #ccc;
}

.nickname-tips {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.nickname-tips text {
  font-size: 24rpx;
  color: #999;
}

.tips-icon {
  margin-left: 8rpx;
}

.quick-fill-btn {
  display: flex;
  align-items: center;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #666;
  border: none;
}

.quick-fill-btn::after {
  border: none;
}

.wechat-avatar-mini {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #f0f0f0;
}

.quick-fill-btn text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 按钮区域 */
.btn-wrapper {
  padding: 40rpx 0;
}

.save-btn {
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a856 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.8;
}

/* 提示区域 */
.tips-section {
  background: #fff9e6;
  border-radius: 24rpx;
  padding: 30rpx;
  border-left: 8rpx solid #ffc107;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #f39c12;
  margin-bottom: 20rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
}

.tips-content text {
  display: block;
  font-size: 24rpx;
  color: #f39c12;
  line-height: 1.6;
  margin-bottom: 12rpx;
}
