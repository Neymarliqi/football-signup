<!-- pages/profile/profile.wxml - 个人中心 -->
<view class="container">
  
  <!-- 头部用户信息卡 -->
  <view class="profile-header">
    <!-- 头像 -->
    <view class="avatar-wrap" bindtap="showAvatarOptions">
      <image class="profile-avatar" src="{{userInfo.avatarUrl || placeholderAvatar}}" mode="aspectFill"></image>
      <view class="avatar-edit-badge">📷</view>
    </view>

    <!-- 用户名 -->
    <view class="name-wrap">
      <view wx:if="{{!editingName}}" class="display-name" bindtap="showNameOptions">
        <text class="name-text">{{userInfo.nickName || '点击设置昵称'}}</text>
        <text class="name-edit-icon">✏</text>
      </view>
      <view wx:else class="edit-name-wrap">
        <input class="name-input" value="{{tempName}}" bindinput="onNameInput" 
               placeholder="输入你的昵称" maxlength="10" focus="{{true}}"/>
        <view class="name-save-btn" bindtap="saveName">✅</view>
        <view class="name-cancel-btn" bindtap="cancelEditName">✕</view>
      </view>
      <view class="uid-text">ID: {{shortOpenid}}</view>
    </view>
  </view>

  <!-- 位置偏好 -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">⚽ 位置偏好 <text class="section-subtitle">（按选择顺序排序，最多3个）</text></view>
      <view class="section-more" bindtap="clearPositions">清空</view>
    </view>
    <view class="position-grid">
      <view wx:for="{{positions}}" wx:key="value"
            class="pos-option {{item.isSelected ? 'pos-option-active' : ''}}"
            bindtap="selectPosition" data-pos="{{item.value}}">
        <text class="pos-emoji">{{item.emoji}}</text>
        <text class="pos-label">{{item.label}}</text>
        <!-- 选中顺序角标：1显示"首"，2、3显示"备" -->
        <view class="pos-order-badge" wx:if="{{item.isSelected}}">{{item.selectOrder === 1 ? '首' : '备'}}</view>
      </view>
    </view>
  </view>

  <!-- 我的统计 -->
  <view class="card">
    <view class="section-title">📊 我的数据</view>
    <view class="stats-row">
      <view class="stat-block">
        <view class="stat-num text-primary">{{myStats.totalGames}}</view>
        <view class="stat-label">参与场次</view>
      </view>
      <view class="stat-block">
        <view class="stat-num text-blue">{{myStats.confirmedCount}}</view>
        <view class="stat-label">已报名</view>
      </view>
      <view class="stat-block">
        <view class="stat-num" style="color: #f39c12;">{{myStats.pendingCount}}</view>
        <view class="stat-label">待定次数</view>
      </view>
      <view class="stat-block">
        <view class="stat-num text-danger">{{myStats.leaveCount}}</view>
        <view class="stat-label">请假次数</view>
      </view>
    </view>
  </view>

  <!-- 参与记录 -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">📅 参与记录</view>
      <view wx:if="{{hasMoreHistory}}" class="section-more" bindtap="goHistoryList">更多 ></view>
    </view>
    <view wx:if="{{history.length === 0}}" class="empty-tip">暂无参与记录</view>
    <view wx:for="{{history}}" wx:key="_id" class="history-item" bindtap="goDetail" data-id="{{item._id}}">
      <view class="history-left">
        <view class="history-title">{{item.title}}</view>
        <view class="history-date">{{item.displayDate}}  {{item.time}}</view>
      </view>
      <view class="history-status tag {{item.myStatusClass}}">{{item.myStatusText}}</view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card">
    <view class="section-title">关于我们</view>
    <view class="about-item" bindtap="about">
      <text class="about-name">约球助手</text>
      <text class="about-version">v{{version}}</text>
    </view>
  </view>

  <view style="height: 160rpx;"></view>
</view>

<!-- 头像选择弹窗 -->
<view class="action-sheet" wx:if="{{showAvatarSheet}}" catchtouchmove="preventScroll">
  <view class="sheet-mask" bindtap="closeAvatarSheet"></view>
  <view class="sheet-content">
    <view class="sheet-title">选择头像</view>
    <view class="sheet-options">
      <!-- 微信头像选项 -->
      <view class="sheet-item-with-icon" bindtap="chooseWechatAvatar">
        <image class="sheet-item-avatar" src="{{wechatUserInfo.avatarUrl || placeholderAvatar}}" mode="aspectFill"></image>
        <view class="sheet-item-info">
          <text class="sheet-item-title">使用微信头像</text>
          <text class="sheet-item-desc">{{wechatUserInfo.nickName || '微信用户'}}</text>
        </view>
      </view>
      <view class="sheet-item" bindtap="chooseAlbumAvatar">📷 从相册选择</view>
      <view class="sheet-item" bindtap="chooseCameraAvatar">📸 拍照</view>
    </view>
    <view class="sheet-cancel" bindtap="closeAvatarSheet">取消</view>
  </view>
</view>

<!-- 昵称选择弹窗 -->
<view class="action-sheet" wx:if="{{showNameSheet}}" catchtouchmove="preventScroll">
  <view class="sheet-mask" bindtap="closeNameSheet"></view>
  <view class="sheet-content">
    <view class="sheet-title">选择昵称</view>
    <view class="sheet-options">
      <!-- 微信昵称选项 -->
      <view class="sheet-item-with-icon" bindtap="chooseWechatName">
        <image class="sheet-item-avatar" src="{{wechatUserInfo.avatarUrl || placeholderAvatar}}" mode="aspectFill"></image>
        <view class="sheet-item-info">
          <text class="sheet-item-title">使用微信昵称</text>
          <text class="sheet-item-desc">{{wechatUserInfo.nickName || '微信用户'}}</text>
        </view>
      </view>
      <view class="sheet-item" bindtap="chooseManualName">✏️ 手动输入</view>
    </view>
    <view class="sheet-cancel" bindtap="closeNameSheet">取消</view>
  </view>
</view>
