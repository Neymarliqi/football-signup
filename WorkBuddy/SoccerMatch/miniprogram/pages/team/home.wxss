/* pages/team/home.wxss */

/* 头部 */
.team-header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.header-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.header-cover-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
}

.header-edit-btn {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: rgba(0,0,0,0.4);
  border-radius: 40rpx;
  z-index: 10;
  backdrop-filter: blur(8rpx);
}

.icon-edit {
  font-size: 28rpx;
}

.label-edit {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.header-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
}

.header-logo-wrap {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
}

.logo-frame {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(10rpx);
  border: 5rpx solid rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.logo-img {
  width: 100%;
  height: 100%;
}

.logo-placeholder-icon {
  font-size: 60rpx;
  opacity: 0.7;
}

.header-info {
  position: absolute;
  bottom: 30rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 2;
}

.team-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5);
  margin-bottom: 8rpx;
}

.team-meta {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* Tab */
.team-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab-active {
  color: #2ecc71;
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2ecc71;
  border-radius: 4rpx;
}

.tab-content {
  padding: 24rpx;
}

/* 简介 */
.team-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: block;
  margin-top: 12rpx;
}

/* 邀请按钮 */
.invite-desc {
  font-size: 26rpx;
  color: #999;
  margin: 12rpx 0 20rpx;
}

.btn-invite-share {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-join {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.join-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
}

.join-status-icon { font-size: 40rpx; }
.join-status-text { font-size: 28rpx; color: #2ecc71; font-weight: bold; }

/* 成员列表 */
.member-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.member-item:last-child { border-bottom: none; }

.member-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.member-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.member-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.member-role {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  display: inline-block;
}

.role-creator {
  background: linear-gradient(135deg, #f39c12, #e67e22);
  color: #fff;
}

.role-admin {
  background: #e8f8f0;
  color: #27ae60;
}

.role-member {
  background: #f5f5f5;
  color: #999;
}

.member-actions {
  display: flex;
  gap: 16rpx;
}

.action-text {
  font-size: 24rpx;
  color: #2ecc71;
}

.action-text.danger {
  color: #e74c3c;
}

/* 活动卡片 */
.activity-mini-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.mini-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.mini-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.mini-date {
  font-size: 24rpx;
  color: #999;
}

.mini-title {
  font-size: 30rpx;
  color: #1a1a2e;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.mini-meta {
  font-size: 24rpx;
  color: #666;
}

/* 散客列表 */
.select-all-btn {
  font-size: 26rpx;
  color: #2ecc71;
}

.casual-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.casual-item:last-child { border-bottom: none; }

.casual-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  flex-shrink: 0;
}

.checkbox-checked {
  background: #2ecc71;
  border-color: #2ecc71;
}

.casual-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.casual-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.casual-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.casual-meta {
  font-size: 22rpx;
  color: #999;
}

/* 底部固定栏 */
.fixed-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.bottom-bar-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  /* 去掉 button 默认样式 */
  border: none;
  outline: none;
  line-height: 1;
}

.bottom-bar-btn::after {
  border: none;
}

.btn-share {
  background: #fff;
  color: #2ecc71;
  border: 2rpx solid #2ecc71;
  box-sizing: border-box;
}

.btn-publish {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
}

.btn-settings {
  background: #f5f5f5;
  color: #666;
  flex: 0.8;
}

/* 一键转入按钮 */
.convert-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 100;
}

.convert-btn {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  padding: 80rpx 0;
  font-size: 28rpx;
}

/* 散客Tab：选中提示条 */
.convert-tip-bar {
  text-align: center;
  font-size: 26rpx;
  color: #2ecc71;
  padding: 20rpx 0 12rpx;
  font-weight: 500;
}

/* 散客Tab底部栏 */
.casual-bar {
  /* 复用 fixed-bottom-bar，仅调整z-index防止被遮挡 */
  z-index: 200;
}

.btn-convert {
  background: linear-gradient(135deg, #8e44ad, #9b59b6);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50rpx;
  text-align: center;
  padding: 22rpx 0;
  flex: 1.2;
}

.btn-disabled {
  background: #ddd;
  color: #999;
}

/* 申请Tab */
.application-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.application-item:last-child {
  border-bottom: none;
}

.application-actions {
  display: flex;
  gap: 16rpx;
}

.btn-approve {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
}

.btn-reject {
  background: #f5f5f5;
  color: #999;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
}

/* 球队信息Tab */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item-label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-item-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  max-width: 60%;
}

.member-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
