<!-- pages/activity/detail.wxml - 活动详情页 -->
<view class="container">

  <!-- 活动头部信息卡 -->
  <view class="detail-header-card">
    <view class="flex-between mb-10">
      <view class="tag {{activity.statusClass}}">{{activity.statusText}}</view>
      <view wx:if="{{isAdmin}}" class="edit-btn" bindtap="editActivity">✏ 编辑</view>
    </view>
    <view class="detail-title">{{activity.title}}</view>
    <view class="detail-desc" wx:if="{{activity.description}}">{{activity.description}}</view>
  </view>

  <!-- 活动信息卡 -->
  <view class="card">
    <view class="section-title">📋 活动信息</view>
    <view class="info-grid">
      <view class="info-grid-item">
        <view class="info-grid-icon">📅</view>
        <view class="info-grid-content">
          <view class="info-grid-label">日期</view>
          <view class="info-grid-value">{{activity.displayDate}}</view>
        </view>
      </view>
      <view class="info-grid-item">
        <view class="info-grid-icon">⏰</view>
        <view class="info-grid-content">
          <view class="info-grid-label">时间</view>
          <view class="info-grid-value">{{activity.time}}</view>
        </view>
      </view>
      <view class="info-grid-item">
        <view class="info-grid-icon">⚽</view>
        <view class="info-grid-content">
          <view class="info-grid-label">赛制</view>
          <view class="info-grid-value">{{activity.matchType}}</view>
        </view>
      </view>
      <view class="info-grid-item">
        <view class="info-grid-icon">💰</view>
        <view class="info-grid-content">
          <view class="info-grid-label">费用</view>
          <view class="info-grid-value fee-value">{{activity.fee > 0 ? activity.fee + '元/人' : '免费'}}</view>
        </view>
      </view>
      <view class="info-grid-item">
        <view class="info-grid-icon">👥</view>
        <view class="info-grid-content">
          <view class="info-grid-label">人数</view>
          <view class="info-grid-value">
            <text class="{{confirmedCount >= activity.maxPlayers ? 'text-danger' : 'text-primary'}}">{{confirmedCount}}</text>
            <text class="text-gray">/{{activity.maxPlayers}}人</text>
          </view>
        </view>
      </view>
      <view class="info-grid-item">
        <view class="info-grid-icon">🏟</view>
        <view class="info-grid-content">
          <view class="info-grid-label">场地</view>
          <view class="info-grid-value">{{activity.fieldType || '待定'}}</view>
        </view>
      </view>
    </view>

    <!-- 地址 -->
    <view class="divider"></view>
    <view class="location-row" bindtap="openMap">
      <view class="location-left">
        <view class="location-icon">📍</view>
        <view class="location-info">
          <view class="location-name">{{activity.locationName}}</view>
          <view class="location-addr">{{activity.location}}</view>
        </view>
      </view>
      <view class="location-nav">导航 ›</view>
    </view>
  </view>

  <!-- 公告/注意事项 -->
  <view class="card" wx:if="{{activity.notice}}">
    <view class="section-title">📢 注意事项</view>
    <view class="notice-text">{{activity.notice}}</view>
  </view>

  <!-- 报名状态统计 -->
  <view class="card">
    <view class="section-title flex-between">
      <text>📊 报名情况</text>
      <text class="stat-detail">共{{totalCount}}人</text>
    </view>
    <view class="stat-row">
      <view class="stat-item stat-green">
        <view class="stat-num">{{confirmedCount}}</view>
        <view class="stat-label">✅ 已报名</view>
      </view>
      <view class="stat-item stat-yellow">
        <view class="stat-num">{{pendingCount}}</view>
        <view class="stat-label">⏳ 待定</view>
      </view>
      <view class="stat-item stat-red">
        <view class="stat-num">{{leaveCount}}</view>
        <view class="stat-label">🙅 请假</view>
      </view>
      <view class="stat-item stat-gray">
        <view class="stat-num">{{activity.maxPlayers - confirmedCount}}</view>
        <view class="stat-label">🪑 空位</view>
      </view>
    </view>
    <!-- 进度条 -->
    <view class="progress-bar-bg mt-20">
      <view class="progress-bar-fill {{confirmedCount >= activity.maxPlayers ? 'bar-full' : 'bar-normal'}}" style="width: {{progressPercent}}%"></view>
    </view>
  </view>

  <!-- 已报名球员列表 -->
  <view class="card">
    <view class="section-title">✅ 已报名 ({{confirmedCount}})</view>
    <view wx:if="{{confirmedPlayers.length === 0}}" class="empty-tip">暂无人报名，快来第一个！</view>
    <view class="player-list">
      <view wx:for="{{confirmedPlayers}}" wx:key="openid" class="player-item">
        <view class="player-rank">{{index + 1}}</view>
        <image class="player-avatar" src="{{item.avatarUrl || '/assets/default_avatar.png'}}" mode="aspectFill"></image>
        <view class="player-info">
          <view class="player-name">{{item.nickName}}</view>
          <view class="player-position" wx:if="{{item.position}}">
            <text class="position-badge">{{item.position}}</text>
          </view>
        </view>
        <view class="player-time">{{item.registerTimeText}}</view>
      </view>
    </view>
  </view>

  <!-- 待定球员 -->
  <view class="card" wx:if="{{pendingPlayers.length > 0}}">
    <view class="section-title">⏳ 待定 ({{pendingCount}})</view>
    <view class="player-list">
      <view wx:for="{{pendingPlayers}}" wx:key="openid" class="player-item pending-item">
        <image class="player-avatar" src="{{item.avatarUrl || '/assets/default_avatar.png'}}" mode="aspectFill"></image>
        <view class="player-info">
          <view class="player-name">{{item.nickName}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 请假球员 -->
  <view class="card" wx:if="{{leavePlayers.length > 0}}">
    <view class="section-title">🙅 请假 ({{leaveCount}})</view>
    <view class="player-list">
      <view wx:for="{{leavePlayers}}" wx:key="openid" class="player-item leave-item">
        <image class="player-avatar" src="{{item.avatarUrl || '/assets/default_avatar.png'}}" mode="aspectFill"></image>
        <view class="player-info">
          <view class="player-name">{{item.nickName}}</view>
          <view class="leave-reason" wx:if="{{item.leaveReason}}">{{item.leaveReason}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 战术板入口（已报名才显示） -->
  <view class="card tactics-entry" wx:if="{{myStatus === 'confirmed'}}" bindtap="goTactics">
    <view class="tactics-left">
      <view class="tactics-icon">🗺</view>
      <view class="tactics-info">
        <view class="tactics-title">战术板</view>
        <view class="tactics-sub">查看队员位置安排</view>
      </view>
    </view>
    <view class="tactics-arrow">›</view>
  </view>

  <!-- 底部报名操作区 -->
  <view class="bottom-action" wx:if="{{activity.status !== 'finished' && activity.status !== 'cancelled'}}">
    <view class="my-status-bar" wx:if="{{myStatus}}">
      <text class="my-status-text">当前状态：</text>
      <view class="tag {{myStatusClass}}">{{myStatusText}}</view>
    </view>

    <view class="action-btns">
      <!-- 未报名时 -->
      <block wx:if="{{!myStatus}}">
        <view class="action-btn btn-confirmed {{confirmedCount >= activity.maxPlayers ? 'btn-disabled' : ''}}"
              bindtap="{{confirmedCount >= activity.maxPlayers ? '' : 'register'}}" data-status="confirmed">
          ✅ 报名参加
        </view>
        <view class="action-btn btn-pending" bindtap="register" data-status="pending">
          ⏳ 暂时待定
        </view>
        <view class="action-btn btn-leave" bindtap="register" data-status="leave">
          🙅 我要请假
        </view>
      </block>

      <!-- 已报名 -->
      <block wx:if="{{myStatus === 'confirmed'}}">
        <view class="action-btn btn-pending" bindtap="changeStatus" data-status="pending">改为待定</view>
        <view class="action-btn btn-leave" bindtap="changeStatus" data-status="leave">请假</view>
        <view class="action-btn btn-cancel" bindtap="cancelRegister">取消报名</view>
      </block>

      <!-- 待定 -->
      <block wx:if="{{myStatus === 'pending'}}">
        <view class="action-btn btn-confirmed {{confirmedCount >= activity.maxPlayers ? 'btn-disabled' : ''}}"
              bindtap="{{confirmedCount >= activity.maxPlayers ? '' : 'changeStatus'}}" data-status="confirmed">
          ✅ 确认报名
        </view>
        <view class="action-btn btn-leave" bindtap="changeStatus" data-status="leave">请假</view>
        <view class="action-btn btn-cancel" bindtap="cancelRegister">取消</view>
      </block>

      <!-- 请假 -->
      <block wx:if="{{myStatus === 'leave'}}">
        <view class="action-btn btn-confirmed {{confirmedCount >= activity.maxPlayers ? 'btn-disabled' : ''}}"
              bindtap="{{confirmedCount >= activity.maxPlayers ? '' : 'changeStatus'}}" data-status="confirmed">
          ✅ 改为报名
        </view>
        <view class="action-btn btn-pending" bindtap="changeStatus" data-status="pending">改为待定</view>
        <view class="action-btn btn-cancel" bindtap="cancelRegister">取消</view>
      </block>
    </view>

    <!-- 满员提示 -->
    <view class="full-tip" wx:if="{{confirmedCount >= activity.maxPlayers && myStatus !== 'confirmed'}}">
      ⚠️ 当前人数已满！可选择待定，候补排队
    </view>
  </view>

  <!-- 弱化的分享按钮 -->
  <view class="share-weak">
    <button class="share-weak-btn" open-type="share">📤 分享给队友</button>
  </view>

  <view style="height: 180rpx;"></view>
</view>

<!-- 头像昵称弹窗 -->
<view class="user-info-modal" wx:if="{{showUserInfoModal}}">
  <view class="modal-mask" bindtap="closeUserInfoModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">完善个人信息</text>
      <view class="modal-close" bindtap="closeUserInfoModal">✕</view>
    </view>
    <view class="modal-body">
      <view class="form-row">
        <view class="form-label">头像</view>
        <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image class="avatar-preview" src="{{tempAvatarUrl || defaultAvatarUrl}}" mode="aspectFill"></image>
        </button>
      </view>
      <view class="form-row">
        <view class="form-label">昵称</view>
        <input class="nickname-input" type="nickname" placeholder="请输入昵称" value="{{tempNickName}}" bindinput="onNickNameInput" />
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn modal-btn-cancel" bindtap="closeUserInfoModal">取消</view>
      <view class="modal-btn modal-btn-confirm" bindtap="saveUserInfo">保存</view>
    </view>
  </view>
</view>
