/* pages/activity/detail.wxss */

/* 头部信息卡 */
.detail-header-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.detail-header-card::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: rgba(46,204,113,0.1);
}

.detail-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #fff;
  margin: 20rpx 0 10rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.detail-desc-wrap {
  margin-top: 10rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.6;
  word-break: break-all;
}

.detail-desc.desc-collapsed {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.detail-desc.desc-expanded {
  display: block;
}

.desc-expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}

.desc-expand-btn:active {
  color: rgba(255,255,255,0.8);
}

.expand-icon {
  font-size: 20rpx;
  transition: transform 0.3s ease;
}

.expand-icon.icon-rotate {
  transform: rotate(180deg);
}

.edit-btn {
  font-size: 26rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
}

.edit-btn:active {
  background: rgba(255,255,255,0.3);
}

/* 头部管理操作区 */
.header-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  position: relative;
  z-index: 10;
}

.header-actions .action-link {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  padding: 8rpx 16rpx;
  position: relative;
  z-index: 11;
}

.header-actions .action-link.delete {
  color: rgba(255,255,255,0.5);
}

.header-actions .action-link:active {
  color: #fff;
}

/* 信息网格 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.info-grid-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-grid-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.info-grid-label {
  font-size: 22rpx;
  color: #aaa;
  margin-bottom: 4rpx;
}

.info-grid-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.fee-value { color: #e74c3c; font-weight: bold; }

.text-danger { color: #e74c3c; font-weight: bold; font-size: 32rpx; }
.text-primary { color: #2ecc71; font-weight: bold; font-size: 32rpx; }
.text-gray { color: #999; }

/* 地址行 */
.location-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.location-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.location-icon { font-size: 40rpx; }

.location-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.location-addr {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.location-nav {
  color: #3498db;
  font-size: 28rpx;
  font-weight: bold;
  padding: 12rpx 20rpx;
  background: #eaf4fd;
  border-radius: 20rpx;
}

/* 注意事项 */
.notice-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  background: #fff9e6;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #f39c12;
}

/* 统计卡 */
.stat-detail { font-size: 24rpx; color: #999; font-weight: normal; }

.stat-row {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
}

.stat-num { font-size: 44rpx; font-weight: bold; margin-bottom: 8rpx; }
.stat-label { font-size: 22rpx; }

.stat-green { background: #e8f8f0; }
.stat-green .stat-num { color: #2ecc71; }

.stat-yellow { background: #fef9e7; }
.stat-yellow .stat-num { color: #f39c12; }

.stat-red { background: #fdecea; }
.stat-red .stat-num { color: #e74c3c; }

.stat-gray { background: #f5f5f5; }
.stat-gray .stat-num { color: #aaa; }

/* 进度条 */
.progress-bar-bg {
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}
.progress-bar-fill {
  height: 100%;
  border-radius: 10rpx;
}
.bar-normal { background: linear-gradient(90deg, #2ecc71, #27ae60); }
.bar-full { background: linear-gradient(90deg, #e74c3c, #c0392b); }

/* 球员列表 */
.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 30rpx 0;
}

.player-list { }

.player-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.player-item:last-child { border-bottom: none; }

.player-rank {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e0e0e0;
  border: 3rpx solid #e8f8f0;
  flex-shrink: 0;
}

.player-info { flex: 1; }

.player-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}

.position-badge {
  display: inline-block;
  background: #e8f8f0;
  color: #2ecc71;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-top: 6rpx;
}

.player-time {
  font-size: 22rpx;
  color: #bbb;
}

.pending-item { opacity: 0.7; }
.leave-item { opacity: 0.5; }

.leave-reason {
  font-size: 22rpx;
  color: #e74c3c;
  margin-top: 4rpx;
}

.more-tip {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  padding: 20rpx 0 10rpx;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 10rpx;
}

/* 战术板入口 */
.tactics-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #e8f8f0, #d4f5e9) !important;
  border: 2rpx solid #2ecc71;
  cursor: pointer;
}

.tactics-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.tactics-icon { font-size: 48rpx; }

.tactics-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.tactics-sub {
  font-size: 24rpx;
  color: #27ae60;
  margin-top: 4rpx;
}

.tactics-arrow {
  font-size: 44rpx;
  color: #2ecc71;
  font-weight: bold;
}

/* 底部操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 100;
  pointer-events: auto;
}

.my-status-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.my-status-text { font-size: 26rpx; color: #666; }

/* 底部操作按钮区 - UI规范：主操作→功能操作→分隔线→管理操作 */
.action-bar-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 左侧主操作（绿色高亮）- 与创建页面统一 */
.action-bar-left {
  flex: 1.2;
  min-width: 0;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  white-space: nowrap;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.35);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.995);
}

/* 中间功能操作（浅红色）- 与主操作统一高度 */
.action-bar-center {
  flex: 1;
  min-width: 0;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  background: #fff5f5;
  color: #ff6b6b;
  border: 2rpx solid #ffe0e0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  white-space: nowrap;
}

.btn-secondary:active {
  background: #ffe8e8;
  transform: scale(0.995);
}

/* 次要按钮禁用状态 */
.btn-secondary-disabled {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  background: #f5f5f5;
  color: #999;
  border: 2rpx solid #e5e5e5;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  white-space: nowrap;
}

/* 分隔线 */
.action-bar-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e5e5e5;
  margin: 0 8rpx;
}

/* 右侧分享（灰色弱化，纯文字）- 与主操作统一高度 */
.action-bar-right {
  width: 80rpx;
}

.btn-share {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  margin: 0;
  background: transparent;
  border: none;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
}

.btn-share::after {
  border: none;
}

.btn-share:active {
  color: #333;
}

/* 禁用状态 */
.btn-disabled {
  background: #ccc !important;
  color: #fff !important;
  box-shadow: none !important;
}

.full-tip {
  text-align: center;
  color: #e74c3c;
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* 操作选择弹窗 */
.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.sheet-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.sheet-content {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.sheet-title {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sheet-options {
  display: flex;
  flex-direction: column;
}

.sheet-item {
  text-align: center;
  padding: 32rpx;
  font-size: 32rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.sheet-item.danger {
  color: #ff6b6b;
}

.sheet-item:active {
  background: #f8f8f8;
}

.sheet-cancel {
  text-align: center;
  padding: 32rpx;
  font-size: 32rpx;
  color: #999;
  background: #f8f8f8;
  margin-top: 16rpx;
  border-radius: 24rpx;
}

.sheet-cancel:active {
  background: #f0f0f0;
}

/* 请假原因弹窗 */
.leave-reason-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.reason-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.reason-tip {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* ====== 头像昵称弹窗 ====== */
.user-info-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  margin-bottom: 40rpx;
}

.form-row {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border-radius: 50%;
  border: 2rpx solid #eee;
  background: #f5f5f5;
  position: relative;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.modal-btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  margin: 0;
  padding: 0;
  border: none;
  line-height: 88rpx;
}

.modal-btn-confirm::after {
  border: none;
}

/* ====== 阅读确认弹窗 ====== */
.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.confirm-content {
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.confirm-body {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.confirm-notice {
  background: #fff9e6;
  border-radius: 16rpx;
  padding: 30rpx;
  border-left: 6rpx solid #f39c12;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.notice-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.notice-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 20rpx;
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-right: 10rpx;
}

.notice-tips {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #e74c3c;
  font-weight: 500;
  padding-top: 20rpx;
  border-top: 1rpx dashed #f39c12;
  flex-shrink: 0;
}

.tip-icon {
  font-size: 32rpx;
}

.confirm-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.confirm-footer .modal-btn-confirm {
  flex: 1;
}

.confirm-footer .btn-disabled {
  background: #ccc !important;
  color: #fff !important;
  opacity: 0.6;
}
