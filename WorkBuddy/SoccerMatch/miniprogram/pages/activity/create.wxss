/* pages/activity/create.wxss */

.page-header {
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 20rpx;
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
}

.page-header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

/* 表单项 */
.form-item { margin-bottom: 30rpx; }
.form-item:last-child { margin-bottom: 0; }

.form-label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.required { color: #e74c3c; }

.form-input {
  width: 100%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e8e8e8;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e8e8e8;
  min-height: 160rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.form-picker {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-picker.placeholder { color: #bbb; }
.picker-arrow { font-size: 36rpx; color: #bbb; }

.form-hint {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 单选组 */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.radio-active {
  color: #2ecc71;
  border-color: #2ecc71;
  background: #e8f8f0;
  font-weight: bold;
}

/* 地址行 */
.location-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pick-location-btn {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  padding: 18rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 数字输入 */
.number-input-row {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 10rpx;
}

.num-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #555;
  font-weight: bold;
}

.num-display {
  font-size: 38rpx;
  font-weight: bold;
  color: #1a1a2e;
  min-width: 120rpx;
  text-align: center;
}

/* 开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-label { font-size: 28rpx; color: #333; }

/* 提交区 */
.submit-area {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(46,204,113,0.35);
}

.cancel-btn {
  background: #fdecea;
  color: #e74c3c;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
}
