<!-- pages/profile/profile.wxml - 个人中心 -->
<view class="container">

  <!-- 头部用户信息卡 - 点击整个模块进入编辑页面 -->
  <view class="profile-header" bindtap="goEditProfile">
    <!-- 头像 -->
    <view class="avatar-wrap">
      <image class="profile-avatar" src="{{userInfo.displayAvatar || userInfo.avatarUrl || placeholderAvatar}}" mode="aspectFill"></image>
    </view>

    <!-- 用户名 -->
    <view class="name-wrap">
      <view class="display-name">
        <text class="name-text">{{userInfo.nickName || '点击设置昵称'}}</text>
      </view>
      <view class="uid-text">ID: {{shortOpenid}}</view>
    </view>

    <!-- 右箭头 -->
    <view class="edit-arrow">></view>
  </view>

  <!-- 位置偏好 -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">⚽ 位置偏好 <text class="section-subtitle">（按选择顺序排序，最多3个）</text></view>
      <view class="section-more" bindtap="clearPositions">清空</view>
    </view>
    <view class="position-grid">
      <view wx:for="{{positions}}" wx:key="value"
            class="pos-option {{item.isSelected ? 'pos-option-active' : ''}}"
            bindtap="selectPosition" data-pos="{{item.value}}">
        <text class="pos-emoji">{{item.emoji}}</text>
        <text class="pos-label">{{item.label}}</text>
        <!-- 选中顺序角标：1显示"首"，2、3显示"备" -->
        <view class="pos-order-badge" wx:if="{{item.isSelected}}">{{item.selectOrder === 1 ? '首' : '备'}}</view>
      </view>
    </view>
  </view>

  <!-- 球队专区 -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">🏆 我的球队</view>
      <view class="section-more" bindtap="goCreateTeam">+ 创建球队</view>
    </view>

    <!-- 骨架屏 - 加载中显示 -->
    <view wx:if="{{loadingTeams}}" class="team-skeleton">
      <view wx:for="{{[1,2]}}" wx:key="*this" class="team-skeleton-item">
        <view class="team-skeleton-logo"></view>
        <view class="team-skeleton-info">
          <view class="team-skeleton-name"></view>
          <view class="team-skeleton-meta">
            <view class="team-skeleton-tag"></view>
            <view class="team-skeleton-count"></view>
          </view>
        </view>
        <view class="team-skeleton-arrow"></view>
      </view>
    </view>

    <!-- 真实数据 - 加载完成后显示 -->
    <block wx:elif="{{myTeams.length > 0}}">
      <view wx:for="{{displayTeams}}" wx:key="_id" class="team-item" bindtap="goTeamHome" data-teamid="{{item._id}}">
        <view class="team-logo">
          <image wx:if="{{item.logoPath}}" class="team-logo-img" src="{{item.logoPath}}" mode="aspectFill"/>
          <text wx:if="{{!item.logoPath}}" class="team-logo-placeholder">⚽</text>
        </view>
        <view class="team-info">
          <text class="team-name">{{item.name}}</text>
          <view class="team-meta-row">
            <text class="{{item.myRole === 'creator' ? 'role-creator' : 'role-member'}}">{{item.myRole === 'creator' ? '👑 创建' : '👤 加入'}}</text>
            <text class="team-meta">👥 {{item.memberCount}}人</text>
          </view>
        </view>
        <view class="team-arrow">›</view>
      </view>

      <view wx:if="{{myTeams.length > 5}}" class="show-more-btn" bindtap="toggleShowAllTeams">
        {{showAllTeams ? '收起 ▲' : '查看全部 ' + myTeams.length + ' 支球队 >'}}
      </view>
    </block>

    <!-- 无球队时显示引导 -->
    <view wx:else class="empty-team-tip">
      <text class="empty-team-icon">🏆</text>
      <text class="empty-team-text">还没有加入任何球队</text>
    </view>

    <!-- 无球队时显示创建按钮 -->
    <view wx:if="{{!loadingTeams && myTeams.length === 0}}" class="btn-create-team" bindtap="goCreateTeam">创建球队</view>
  </view>

  <!-- 我的统计 -->
  <view class="card">
    <view class="section-title">📊 我的数据</view>
    <view class="stats-row">
      <view class="stat-block">
        <view class="stat-num text-primary">{{myStats.totalGames}}</view>
        <view class="stat-label">参与场次</view>
      </view>
      <view class="stat-block">
        <view class="stat-num text-blue">{{myStats.confirmedCount}}</view>
        <view class="stat-label">已报名</view>
      </view>
      <view class="stat-block">
        <view class="stat-num" style="color: #f39c12;">{{myStats.pendingCount}}</view>
        <view class="stat-label">待定次数</view>
      </view>
      <view class="stat-block">
        <view class="stat-num text-danger">{{myStats.leaveCount}}</view>
        <view class="stat-label">请假次数</view>
      </view>
    </view>
  </view>

  <!-- 参与记录 -->
  <view class="card">
    <view class="section-header">
      <view class="section-title">📅 参与记录</view>
      <view wx:if="{{hasMoreHistory}}" class="section-more" bindtap="goHistoryList">更多 ></view>
    </view>
    <view wx:if="{{history.length === 0}}" class="empty-tip">暂无参与记录</view>
    <view wx:for="{{history}}" wx:key="_id" class="history-item" bindtap="goDetail" data-id="{{item._id}}">
      <view class="history-left">
        <view class="history-title">{{item.title}}</view>
        <view class="history-date">{{item.displayDate}}  {{item.time}}</view>
      </view>
      <view class="history-status tag {{item.myStatusClass}}">{{item.myStatusText}}</view>
    </view>
  </view>

  <!-- 设置菜单 -->
  <view class="card">
    <view class="section-title">⚙️ 设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goTemplates">
        <view class="menu-left">
          <text class="menu-icon">📋</text>
          <text class="menu-name">我的模板</text>
        </view>
        <text class="menu-count" wx:if="{{templateCount > 0}}">{{templateCount}}</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goPrivacy">
        <view class="menu-left">
          <text class="menu-icon">🔒</text>
          <text class="menu-name">隐私保护指引</text>
        </view>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card">
    <view class="section-title">关于我们</view>
    <view class="about-item" bindtap="about">
      <text class="about-name">来踢球</text>
      <text class="about-version">v{{version}}</text>
    </view>
  </view>

  <view style="height: 160rpx;"></view>
</view>

<!-- 注册弹窗 -->
<register-modal show="{{showRegisterModal}}" bind:registered="onRegistered" bind:close="onCloseRegister" />
