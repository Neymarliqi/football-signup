/* pages/profile/profile.wxss */

/* 头部个人信息卡 */
.profile-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
  border-radius: 24rpx;
  padding: 50rpx 30rpx 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(46,204,113,0.6);
  background: #2d2d4e;
}

.avatar-edit-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  background: #2ecc71;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.name-wrap { flex: 1; }

.display-name {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.name-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.name-edit-icon {
  color: rgba(255,255,255,0.5);
  font-size: 28rpx;
}

.edit-name-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.name-input {
  flex: 1;
  background: rgba(255,255,255,0.1);
  color: #fff;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.name-input::placeholder { color: rgba(255,255,255,0.4); }

.name-save-btn {
  background: #2ecc71;
  color: #fff;
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.name-cancel-btn {
  background: rgba(255,255,255,0.15);
  color: #fff;
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.uid-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

/* 位置偏好 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.position-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.pos-option {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.pos-option-active {
  background: #e8f8f0;
  border-color: #2ecc71;
}

.pos-emoji { font-size: 36rpx; display: block; margin-bottom: 8rpx; }

.pos-label {
  font-size: 22rpx;
  color: #555;
  display: block;
}

.pos-option-active .pos-label { color: #27ae60; font-weight: bold; }

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-block { text-align: center; }

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #aaa;
}

.text-primary { color: #2ecc71; }
.text-blue { color: #3498db; }
.text-danger { color: #e74c3c; }

/* 历史记录 */
.empty-tip {
  text-align: center;
  color: #bbb;
  padding: 30rpx 0;
  font-size: 26rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.history-item:last-child { border-bottom: none; }

.history-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.history-date {
  font-size: 22rpx;
  color: #aaa;
}

.history-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.setting-item:last-child { border-bottom: none; }

.setting-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-icon { font-size: 32rpx; }
.setting-label { font-size: 28rpx; color: #333; }
.setting-arrow { font-size: 36rpx; color: #bbb; }
.setting-version { font-size: 24rpx; color: #bbb; }

/* 管理员申请 */
.admin-apply {
  display: flex;
  align-items: center;
  gap: 20rpx;
  border: 2rpx dashed #ddd;
}

.apply-icon { font-size: 44rpx; }

.apply-info { flex: 1; }

.apply-title {
  font-size: 28rpx;
  color: #555;
  font-weight: 500;
}

.apply-sub {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 4rpx;
}

.apply-arrow { font-size: 36rpx; color: #bbb; }

/* 管理员标识 */
.admin-badge-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #1a1a2e, #0f3460);
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
}

.admin-badge {
  color: #2ecc71;
  font-size: 28rpx;
  font-weight: bold;
}

.admin-go-btn {
  background: rgba(46,204,113,0.2);
  color: #2ecc71;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: 2rpx solid #2ecc71;
}
