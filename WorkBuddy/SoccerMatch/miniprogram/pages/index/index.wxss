/* pages/index/index.wxss */

/* 头部横幅 */
.header-banner {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.header-banner::after {
  content: '⚽';
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  font-size: 160rpx;
  opacity: 0.08;
  transform: rotate(15deg);
}

.header-inner { flex: 1; }

.header-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ball-icon { font-size: 48rpx; }

.title-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.header-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 12rpx;
}

.admin-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: rgba(255,255,255,0.15);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  backdrop-filter: blur(4px);
}

/* 公告栏 */
.announce-wrap {
  background: linear-gradient(135deg, #fff9e6, #fffbf0);
  border: 2rpx solid #f39c12;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.announce-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.announce-icon { font-size: 32rpx; }

.announce-title {
  font-size: 26rpx;
  color: #e67e22;
  font-weight: bold;
  white-space: nowrap;
}

.announce-swiper { flex: 1; }

.announce-item {
  display: flex;
  align-items: center;
  height: 60rpx;
}

.announce-text {
  font-size: 26rpx;
  color: #856404;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 50rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 44rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.filter-item.active {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(46,204,113,0.3);
}

/* 活动卡片 */
.activity-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}

.activity-card:active {
  transform: scale(0.995);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-top {
  margin-bottom: 16rpx;
}

.act-status-tag {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

.act-time-badge {
  font-size: 24rpx;
  color: #666;
  display: flex;
  align-items: center;
}

.act-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

.act-info-row {
  display: flex;
  gap: 30rpx;
  margin-bottom: 12rpx;
}

.act-info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  overflow: hidden;
}

.info-icon { font-size: 28rpx; flex-shrink: 0; }
.info-text { font-size: 26rpx; color: #555; }

.location-item {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.location-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  max-width: 100%;
}

/* 报名进度 */
.register-section { margin-bottom: 20rpx; }
.register-label { font-size: 26rpx; color: #666; }
.register-count { font-size: 26rpx; display: flex; align-items: baseline; }
.count-num { font-size: 38rpx; font-weight: bold; }
.count-ok { color: #2ecc71; }
.count-full { color: #e74c3c; }
.count-sep { color: #bbb; margin: 0 6rpx; }
.count-max { color: #999; }

.progress-bar-bg {
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.4s ease;
}

.bar-normal { background: linear-gradient(90deg, #2ecc71, #27ae60); }
.bar-full { background: linear-gradient(90deg, #e74c3c, #c0392b); }

/* 球员头像列表 */
.players-section { margin-bottom: 20rpx; }

.players-title {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.pending-hint { color: #f39c12; }
.leave-hint { color: #e74c3c; }

.avatar-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: flex-start;
}

.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.avatar-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #e8f8f0;
}

.avatar-name {
  font-size: 20rpx;
  color: #666;
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.avatar-more {
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
  color: #666;
  font-size: 22rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.avatar-more:active .more-circle {
  background: #e0e0e0;
  transform: scale(0.95);
}

/* 我的状态 */
.my-status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.my-status-label { font-size: 26rpx; color: #666; }

/* 卡片按钮区 - 左对齐，视觉层次分明 */
.card-btns {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

/* 主操作按钮 - 查看详情 */
.card-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-view {
  background: #1a1a2e;
  color: #fff;
}

/* 功能操作按钮 - 战术板 */
.btn-tactics {
  background: #27ae60;
  color: #fff;
}

/* 分隔线 - 区分主操作和管理操作 */
.action-divider {
  width: 1rpx;
  height: 32rpx;
  background: #e0e0e0;
  margin: 0 8rpx;
}

/* 管理操作链接 - 弱化文字 */
.action-link {
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 12rpx;
}

/* 删除操作特殊标记 */
.action-link.delete {
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #bbb;
}
.empty-sub {
  font-size: 26rpx;
  color: #2ecc71;
  margin-top: 16rpx;
}


