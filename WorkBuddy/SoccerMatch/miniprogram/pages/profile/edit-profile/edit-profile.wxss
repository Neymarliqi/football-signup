/* pages/profile/edit-profile/edit-profile.wxss */
page {
  background-color: #fff;
}

.container {
  padding: 60rpx 40rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 80rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f5f5f5;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.avatar-icon {
  font-size: 80rpx;
  color: #ccc;
}

/* 昵称区域 */
.nickname-section {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #e5e5e5;
  padding: 30rpx 0;
  margin-bottom: 60rpx;
}

.nickname-label {
  font-size: 32rpx;
  color: #000;
  margin-right: 40rpx;
  min-width: 80rpx;
}

.nickname-input {
  flex: 1;
  font-size: 32rpx;
  color: #000;
  height: 60rpx;
  line-height: 60rpx;
}

.nickname-input::placeholder {
  color: #b2b2b2;
}

/* 保存按钮 */
.save-section {
  margin-top: 80rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 8rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.8;
}
