/* pages/profile/templates/templates.wxss */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding: 20rpx 0 80rpx;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 0;
}
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.8;
}
.empty-btn {
  margin-top: 48rpx;
  padding: 20rpx 56rpx;
  background: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.empty-btn:active {
  opacity: 0.85;
}

/* ========== 列表区域 ========== */
.list {
  padding: 0 24rpx;
}
.list-tip {
  font-size: 24rpx;
  color: #bbb;
  padding: 4rpx 8rpx 16rpx;
}

/* ========== 模板卡片 ========== */
.tpl-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.tpl-card:active {
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
}

/* 卡片头部 */
.card-header {
  padding: 28rpx 28rpx 20rpx;
}
.card-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}
.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-time {
  font-size: 24rpx;
  color: #999;
}

/* 标签 */
.card-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 3rpx 14rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  color: #fff;
}
.card-tag.blue {
  background: #4a9eff;
}
.card-tag.green {
  background: #52c41a;
}

/* 分割线 */
.card-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0 28rpx;
}

/* 卡片详情 */
.card-body {
  padding: 20rpx 28rpx 16rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 32rpx;
  margin-bottom: 14rpx;
}
.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}
.info-label {
  font-size: 24rpx;
  color: #bbb;
  flex-shrink: 0;
}
.info-val {
  font-size: 26rpx;
  color: #444;
  flex: 1;
  min-width: 0;
}
.info-val.single-line {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.fee-val {
  color: #fa8c16;
  font-weight: 500;
}

.muted-val {
  color: #999;
}

/* 描述 */
.info-desc-row {
  padding-top: 4rpx;
  margin-bottom: 4rpx;
}
.info-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
  word-break: break-all;
}

/* 底部操作栏 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 28rpx 20rpx;
  border-top: 1rpx solid #f5f5f5;
}
.footer-date {
  font-size: 22rpx;
  color: #ccc;
}
.footer-actions {
  display: flex;
  align-items: center;
  gap: 0;
}
.action-link {
  font-size: 26rpx;
  color: #999;
  padding: 4rpx 16rpx;
}
.action-link:active {
  color: #666;
}
.action-link.danger {
  color: #bbb;
}
.action-link.danger:active {
  color: #ff7875;
}
.action-divider {
  width: 1rpx;
  height: 24rpx;
  background: #e5e5e5;
}

/* ========== 编辑弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.2s, visibility 0.2s;
  z-index: 900;
}
.modal-mask.show {
  opacity: 1;
  visibility: visible;
}
.modal-box {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.92);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  z-index: 901;
}
.modal-box.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}
.modal-inner {
  padding: 40rpx 36rpx 32rpx;
}
.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}
.modal-input-wrap {
  position: relative;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 100rpx 0 24rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #e8e8e8;
}
.modal-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
}
.modal-input-count {
  position: absolute;
  right: 20rpx;
  font-size: 22rpx;
  color: #bbb;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}
.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}
.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}
.modal-btn.cancel:active {
  background: #ebebeb;
}
.modal-btn.confirm {
  background: #07c160;
  color: #fff;
}
.modal-btn.confirm:active {
  background: #06ad56;
}
