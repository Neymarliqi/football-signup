/* pages/profile/profile.wxss */

/* 头部个人信息卡 */
.profile-header {
  background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
  border-radius: 24rpx;
  padding: 50rpx 30rpx 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  position: relative;
  transition: opacity 0.2s;
}

.profile-header:active {
  opacity: 0.8;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(46,204,113,0.6);
  background: #2d2d4e;
}

.name-wrap {
  flex: 1;
}

.display-name {
  margin-bottom: 10rpx;
}

.name-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.uid-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}

/* 右箭头 */
.edit-arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.6);
  font-weight: bold;
  margin-left: 10rpx;
}

/* 位置偏好 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.section-more {
  font-size: 26rpx;
  color: #666;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.position-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.pos-option {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  position: relative;
}

.pos-option-active {
  background: #e8f8f0;
  border-color: #2ecc71;
}

.pos-emoji { font-size: 36rpx; display: block; margin-bottom: 8rpx; }

.pos-label {
  font-size: 22rpx;
  color: #555;
  display: block;
}

.pos-option-active .pos-label { color: #27ae60; font-weight: bold; }

/* 选择顺序角标 - 参考微信图片选择：首/备 */
.pos-order-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background: #2ecc71;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-block { text-align: center; }

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #aaa;
}

.text-primary { color: #2ecc71; }
.text-blue { color: #3498db; }
.text-danger { color: #e74c3c; }

/* 历史记录 */
.empty-tip {
  text-align: center;
  color: #bbb;
  padding: 30rpx 0;
  font-size: 26rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.history-item:last-child { border-bottom: none; }

.history-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.history-date {
  font-size: 22rpx;
  color: #aaa;
}

.history-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

/* 设置菜单 */
.menu-list {
  margin-top: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-name {
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 关于 */
.about-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.about-name {
  font-size: 28rpx;
  color: #333;
}

.about-version {
  font-size: 24rpx;
  color: #999;
}

/* ====== 底部弹窗样式 ====== */
.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
}

.sheet-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
}

.sheet-content {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx;
  background-color: transparent;
  border-radius: 24rpx;
  overflow: hidden;
}

.sheet-title {
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  padding: 30rpx;
}

.sheet-options {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.sheet-item {
  text-align: center;
  padding: 32rpx;
  font-size: 32rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.sheet-item:active {
  background: #f8f8f8;
}

/* 带图标的选项 */
.sheet-item-with-icon {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sheet-item-with-icon:active {
  background: #f8f8f8;
}

.sheet-item-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.sheet-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.sheet-item-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.sheet-item-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}

.sheet-cancel {
  text-align: center;
  padding: 32rpx;
  font-size: 32rpx;
  color: #999;
  background: #f8f8f8;
  margin-top: 16rpx;
  border-radius: 24rpx;
}

.sheet-cancel:active {
  background: #f0f0f0;
}
