/* pages/tactics/tactics.wxss */
page {
  background: #1a9f5e;
  height: 100%;
  overflow: hidden;
  overscroll-behavior: none;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #1a9f5e;
  overflow: hidden;
  touch-action: none;
}

/* 足球场 */
.field-container {
  padding: 20rpx 30rpx 0;
  display: flex;
  justify-content: center;
  align-items: flex-start;
}

.field {
  width: 100%;
  max-width: 650rpx;
  aspect-ratio: 0.75;
  background: #1a9f5e;
  position: relative;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  box-sizing: border-box;
}

/* 场地线条 */
.field-lines {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.field-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.center-line {
  position: absolute;
  top: 50%;
  left: 2rpx;
  right: 2rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.6);
  transform: translateY(-50%);
}

.center-circle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120rpx;
  height: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

/* 禁区（上） */
.penalty-area-top {
  position: absolute;
  top: 2rpx;
  left: 50%;
  width: 300rpx;
  height: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-top: none;
  transform: translateX(-50%);
}

/* 球门区（上） */
.goal-area-top {
  position: absolute;
  top: 2rpx;
  left: 50%;
  width: 160rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-top: none;
  transform: translateX(-50%);
}

/* 禁区（下） */
.penalty-area-bottom {
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  width: 300rpx;
  height: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-bottom: none;
  transform: translateX(-50%);
}

/* 球门区（下） */
.goal-area-bottom {
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  width: 160rpx;
  height: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  border-bottom: none;
  transform: translateX(-50%);
}



/* 场上球员 */
.player {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translate(-50%, -50%);
  z-index: 10;
  transition: none;
}

.player.selected {
  z-index: 20;
}

.player.selected .player-avatar {
  border: 4rpx solid #ff6b35;
  box-shadow: 0 0 20rpx rgba(255, 107, 53, 0.5);
}

.player.dragging {
  opacity: 0.5;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  background: #fff;
}

.player-name {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 30rpx 4rpx;
  position: relative;
  background: transparent;
  margin-top: 4px;
}

.divider::before {
  content: '';
  flex: 1;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.4);
}

.divider::after {
  content: '';
  flex: 1;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.4);
}

.divider-text {
  padding: 0 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 替补球员 */
.bench-container {
  display: flex;
  flex-wrap: wrap;
  padding: 8rpx 30rpx;
  gap: 40rpx;
  flex: 1;
  min-height: 300rpx;
  overflow-y: auto;
}

.bench-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: none;
}

.bench-player.dragging {
  opacity: 0.5;
}

.bench-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  background: #fff;
}

.bench-name {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #fff;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部保存按钮 */
.bottom-bar {
  padding: 20rpx 60rpx 40rpx;
  margin-top: auto;
}

.save-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #ff6b35;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 45rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.9;
}
