/* components/template-picker/template-picker.wxss */

/* ========== 遮罩层 ========== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease, visibility 0.25s ease;
  z-index: 900;
}
.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

/* ========== 弹窗 ========== */
.picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  transform: translateY(100%);
  transition: transform 0.25s ease;
  z-index: 901;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.picker-popup.show {
  transform: translateY(0);
}

/* ========== 头部 ========== */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.picker-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

/* ========== 列表 ========== */
.picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 24rpx;
}

/* ========== 无模板提示 ========== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.empty-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

/* ========== 模板项 ========== */
.tpl-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  position: relative;
  transition: all 0.2s ease;
}
.tpl-item:active {
  background: #f0f2f5;
}
.tpl-item.tpl-selected {
  background: #e8f4ff;
  border-color: #4a9eff;
}

/* 选中勾选标记 */
.tpl-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #4a9eff;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

/* 模板信息 */
.tpl-info {
  flex: 1;
  min-width: 0;
}
.tpl-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}
.tpl-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.tpl-badge {
  font-size: 22rpx;
  color: #fff;
  background: #4a9eff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.tpl-detail-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tpl-time {
  font-size: 24rpx;
  color: #666;
}
.tpl-team {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280rpx;
}

/* 费用标签 */
.tpl-fee {
  font-size: 22rpx;
  color: #fa8c16;
  background: #fff7e6;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  margin-left: 8rpx;
}

/* 场地名称 */
.tpl-venue {
  font-size: 22rpx;
  color: #888;
}

/* 场地类型标签 */
.tpl-badge-type {
  background: #52c41a;
}

/* 活动描述行 */
.tpl-desc-row {
  margin-top: 8rpx;
}
.tpl-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 删除按钮（底部左侧，和勾选标记对齐） */
.tpl-actions {
  flex-shrink: 0;
  margin-left: -8rpx;
}
.tpl-delete {
  font-size: 24rpx;
  color: #ff7875;
  padding: 8rpx 16rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1rpx solid #ff7875;
}
.tpl-delete:active {
  background: #fff1f0;
}

/* ========== 底部提示 ========== */
.picker-footer {
  padding: 20rpx 32rpx 28rpx;
  font-size: 24rpx;
  color: #bbb;
  text-align: center;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
