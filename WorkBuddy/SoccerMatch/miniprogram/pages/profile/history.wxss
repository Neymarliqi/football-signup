/* pages/profile/history.wxss */

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-block {
  text-align: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

.text-primary { color: #2ecc71; }
.text-blue { color: #3498db; }
.text-danger { color: #e74c3c; }

/* 历史记录列表 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  padding: 60rpx 0;
  font-size: 26rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  flex: 1;
  min-width: 0;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-date {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.history-location {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

/* 标签样式 */
.tag-green {
  background: #e8f8f0;
  color: #27ae60;
}

.tag-yellow {
  background: #fef9e7;
  color: #f39c12;
}

.tag-red {
  background: #fdedec;
  color: #e74c3c;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #999;
}

.no-more-tip {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #bbb;
}
